# ===================================================================
# RETROCLOUD — CONFIGURACION DEL ENTORNO
# Copia este archivo como .env y completa tus valores propios.
# NUNCA subas el archivo .env a GitHub.
# ===================================================================

# --- Rutas del sistema ---
ROMS_PATH=/mnt/tu_disco/Roms

# --- Usuario del host ---
HOST_USER=tu_usuario
PUID=1000
PGID=1000

# --- Zona horaria ---
TZ=America/Argentina/Buenos_Aires

# --- Monitor y Workspace (Hyprland) ---
TARGET_MONITOR=TV-STREAM
HOST_MONITOR=DP-1
TARGET_WORKSPACE=10

# --- qBittorrent ---
QBIT_PORT=8080
QBIT_TORRENT_PORT=60881

# --- Sync de saves (opcional) ---
SAVE_SYNC_HOST=
SAVE_SYNC_USER=
SAVE_SYNC_PATH=/mnt/saves/retrocloud
